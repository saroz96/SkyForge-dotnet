# Create or edit .gitignore
cat > .gitignore << EOF
# .NET build artifacts
**/bin/
**/obj/
*.dll
*.exe
*.pdb
*.cache

# Environment files
.env
appsettings.json
appsettings.Production.json

# Frontend
node_modules/
dist/
build/

# IDE
.vscode/
.idea/
*.suo
*.user

# Logs
*.log
**/logs/

# OS generated files
.DS_Store
Thumbs.db
EOF

echo "# Google Drive Credentials" >> .gitignore
echo "SkyForge/SkyForge/credentials.json" >> .gitignore
echo "SkyForge/SkyForge/credentials_web.json" >> .gitignore
echo "SkyForge/SkyForge/GoogleDriveTokens/" >> .gitignore
echo "*.token" >> .gitignore
echo "*.TokenResponse-*" >> .gitignore

echo "GoogleDriveTokens/" >> .gitignore
echo "credentials.json" >> .gitignore
echo "credentials_web.json" >> .gitignore
echo "appsettings.json" >> .gitignore

echo "SkyForge/SkyForge/GoogleDriveTokens/" >> .gitignore
echo "SkyForge/SkyForge/credentials.json" >> .gitignore
echo "SkyForge/SkyForge/credentials_web.json" >> .gitignore
echo "SkyForge/SkyForge/appsettings.json" >> .gitignore


