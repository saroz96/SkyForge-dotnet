# Create or edit .gitignore
cat > .gitignore << EOF
# .NET build artifacts
**/bin/
**/obj/
*.dll
*.exe
*.pdb
*.cache

# Environment files
.env
appsettings.json
appsettings.Production.json

# Frontend
node_modules/
dist/
build/

# IDE
.vscode/
.idea/
*.suo
*.user

# Logs
*.log
**/logs/

# OS generated files
.DS_Store
Thumbs.db
EOF